<div class="login-card">
  <h2>Change Password</h2>
  <p class="subtitle">Update your account password</p>
  <form id="changePasswordForm" class="login-form">
    <div class="form-group">
      <label for="currentPassword">Current Password</label>
      <input type="password" id="currentPassword" name="currentPassword" placeholder="Enter your current password" required>
    </div>
    <div class="form-group">
      <label for="newPassword">New Password</label>
      <input type="password" id="newPassword" name="newPassword" placeholder="Enter new password (min 8 characters)" required>
    </div>
    <div class="form-group">
      <label for="confirmPassword">Confirm New Password</label>
      <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm new password" required>
    </div>
    <div id="passwordError" style="display:none;"></div>
    <div id="passwordSuccess" style="display:none;"></div>
    <button type="submit" class="login-btn">Update Password</button>
  </form>
  <p class="register-link"><a href="/profile">Back to Profile</a></p>
</div>
