{{!-- Public Profile page --}}
{{#if profileUser}}
<div class="profile-header">
  <div class="avatar-section">
    <div class="avatar">
      {{#if profileUser.avatarUrl}}
        <img src="{{profileUser.avatarUrl}}" style="width:100%;height:100%;border-radius:50%;object-fit:cover;">
      {{else}}
        <span>{{getInitials profileUser.firstName profileUser.lastName}}</span>
      {{/if}}
    </div>
  </div>
  <div class="header-info">
    <h1>{{profileUser.firstName}} {{profileUser.lastName}}</h1>
    <p class="email">{{profileUser.email}}</p>
    <div class="badges">
      <span class="badge student">{{#if (eq profileUser.accountType "technician")}}Technician{{else}}Student{{/if}}</span>
      <span class="badge college">{{profileUser.college}}</span>
    </div>
    {{#if profileUser.bio}}
    <p class="bio">{{profileUser.bio}}</p>
    {{/if}}
  </div>
</div>

{{!-- Current Reservations (non-anonymous only) --}}
<div class="profile-card">
  <div class="card-header"><h3>Current Reservations</h3></div>
  <div class="settings-list">
    {{#each reservations}}
      <div class="setting-item">
        <div class="setting-info">
          <h4>{{this.lab}} - Seat {{this.seat}}</h4>
          <p>{{formatDate this.date}} | {{formatTimeSlots this.timeSlots}}</p>
        </div>
        <span class="status-badge upcoming">Upcoming</span>
      </div>
    {{else}}
      <div class="setting-item">
        <div class="setting-info"><p>No current reservations</p></div>
      </div>
    {{/each}}
  </div>
</div>

{{else}}
<div class="page-header" style="text-align:center;color:#fff;">
  <h1>User Not Found</h1>
  <p>The requested user profile could not be found.</p>
  <a href="/users" class="back-link">Back to Find Users</a>
</div>
{{/if}}
